# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prajashakti

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── S3 / LocalStack ──────────────────────────────────────────────────────────
# Local dev: point to LocalStack. In production, remove endpoint + use real credentials.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET=prajashakti-media
AWS_S3_ENDPOINT=http://localhost:4566

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
