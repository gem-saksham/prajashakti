# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_TTL_SECONDS=2592000

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_PROVIDER=console                # console | msg91
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_PER_HOUR=5
OTP_LOCK_DURATION_SECONDS=900
# MSG91 (required when OTP_PROVIDER=msg91)
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=PRJSHK
# MSG91_TEMPLATE_ID=

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/prajashakti

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── S3 / LocalStack ──────────────────────────────────────────────────────────
# Local dev: point to LocalStack. In production, remove endpoint + use real credentials.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET=prajashakti-media
AWS_S3_ENDPOINT=http://localhost:4566

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
