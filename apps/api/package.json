{
  "name": "@prajashakti/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=.env src/server.js",
    "start": "node src/server.js",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.cjs --runInBand",
    "test:watch": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.cjs --runInBand --watch",
    "test:coverage": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.cjs --runInBand --coverage",
    "test:auth": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.cjs --runInBand tests/routes/auth.test.js",
    "migrate:up": "node-pg-migrate up --migrations-dir migrations --migration-file-extension cjs",
    "migrate:down": "node-pg-migrate down --migrations-dir migrations --migration-file-extension cjs",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations",
    "seed": "node --env-file=.env scripts/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1020.0",
    "@aws-sdk/s3-request-presigner": "^3.1020.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prajashakti/shared": "*",
    "dompurify": "^3.3.3",
    "dotenv": "^16.4.0",
    "fastify": "^5.1.0",
    "ioredis": "^5.10.1",
    "jsdom": "^29.0.2",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "node-pg-migrate": "^7.9.1"
  }
}
